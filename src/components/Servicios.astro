---

import { Images } from "../config/images";

---

<!--Div INTRO  -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 p-6 items-center relative">
       
  <!-- Imagen principal -->
  <div class="w-full h-[400px] lg:h-full relative">
    <img
      src={Images.techpeopple.src.src} 
      alt={Images.techpeopple.alt}
      class="w-full h-full object-cover rounded-xl"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/30 to-transparent rounded-xl"></div>
  </div>
  <!-- Texto con burbujas animadas -->
  <div class="flex flex-col items-start text-left space-y-6 px-2 lg:px-0 relative">

  
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-black leading-tight">
      Una solución <br />
      completa de Software <br />
      para tu negocio
    </h2>
    <p class="text-base sm:text-lg text-gray-700">
      Un <strong>paquete tecnológico integral</strong>, intuitivo y robusto,
      diseñado para brindarte la <strong>autonomía</strong> en la gestión diaria
      de tu empresa y garantizar un <strong>ROI real y sostenible</strong>.
    </p>
     <div class="absolute -top-5 -left-6 h-20 w-20 rounded-full bg-[#f69917]/20 border-2 border-[#f69917] shadow-md"></div>

  </div>

</div>

<!-- Cards de servicios -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 p-4">
  
  <!-- Desarrollo Web -->
  <div class="group relative hover:border-amber-300 flex flex-col items-center justify-between border border-gray-300 rounded-2xl shadow-lg transition-transform duration-300 overflow-visible">
    <div class="relative w-full h-[200px] flex justify-center items-center">
      <img
        src={Images.software.src.src} 
        alt={Images.software.alt}
        transition:name="img-web"
        class="relative  rounded-md  z-10 max-h-full max-w-[250px] object-contain transition-all duration-500 group-hover:-translate-y-6 group-hover:scale-110"
        fetchpriority="high"
      />
    </div>
<h3 class="mt-4 text-xl font-semibold text-black text-center"  transition:name="tittle-web">
  Desarrollo Web y Fábrica de Software
</h3>
    <div class="w-full rounded-b-2xl p-4 flex flex-col items-center">
<p class="text-xs sm:text-lg md:text-sm text-gray-700 text-center leading-relaxed">
  Creamos <strong>sitios web modernos</strong> y 
  <strong>software a medida</strong>, priorizando 
  <strong>rendimiento, seguridad y escalabilidad</strong> para que tu negocio crezca contigo.
</p>


       <a href="/devweb" class="text-xs mt-3 bg-black text-white cursor-pointer font-semibold px-4 py-1 rounded-lg shadow-md hover:text-white transition-colors duration-300 hidden group-hover:flex">
        Ver más
      </a>
    </div>
  </div>

  <!-- Automatización / IA -->
  <div class="group relative hover:border-amber-300 flex flex-col items-center justify-between border border-gray-300 rounded-2xl shadow-lg transition-transform duration-300 overflow-visible">
    <div class="relative w-full h-[200px] flex justify-center items-center">
      <img
        src={Images.IA.src.src} 
        alt={Images.IA.alt}
        class="relative  rounded-md  z-10 max-h-full max-w-[250px] object-contain transition-all duration-500 group-hover:-translate-y-6 group-hover:scale-110"
        fetchpriority="high"
      />
    </div>
    <h3 class="mt-4 text-lg font-semibold text-black text-center" transition:name="tittle-automated">
      Automatización / IA
    </h3>
    <div class="w-full rounded-b-2xl p-4 flex flex-col items-center">
     <p class="text-xs sm:text-lg md:text-sm text-gray-700 text-center leading-relaxed">
        Automatizamos procesos mediante <strong>RPA</strong> y <strong>chatbots personalizados</strong>, además de integraciones con plataformas como <strong>Google Calendar</strong>, <strong>Meet</strong>, <strong>WhatsApp</strong> y más.
      </p>
   <a href="/automated" class="text-xs mt-3 bg-black text-white cursor-pointer font-semibold px-4 py-1 rounded-lg shadow-md hover:text-white transition-colors duration-300 hidden group-hover:flex">
        Ver más
   </a>
    </div>
  </div>

</div>
